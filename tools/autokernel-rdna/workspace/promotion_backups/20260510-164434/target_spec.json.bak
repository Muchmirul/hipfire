{
  "_comment": "Target spec for gemv_hfq4g256 — generated by author_kernel.sh for Phase 14.",
  "_note": "This is the fixed evaluator spec. Update shapes from actual model if they change.",
  "kernel_name": "gemv_hfq4g256",
  "kernel_func_name": "gemv_hfq4g256",
  "kernel_purpose": "Dequantize-and-matvec for HFQ4-G256 weight format. One output row per block. Called at every decode step for all linear projections (Q, K, V, O, gate, up, down) in Qwen3.5-27B.",
  "source_file": "kernels/src/gemv_hfq4g256.hip",
  "gfx1201_variant": "kernels/src/gemv_hfq4g256.gfx1201.hip",
  "gfx12_variant": null,
  "dispatch_path": "crates/rdna-compute/src/kernels.rs",
  "dispatch_fn": "gemv_hfq4g256_for_arch()",
  "arch": "gfx1201",
  "quant_format": "HFQ4-G256",
  "group_size": 256,
  "group_bytes": 136,
  "weight_bits": 4,
  "weights_per_group": 256,
  "kernel_args": [
    {"name": "A",    "type": "const char* __restrict__",  "desc": "packed weight matrix, row-major, groups_per_row * group_bytes per row"},
    {"name": "x",    "type": "const float* __restrict__", "desc": "input activation vector, length K, float32"},
    {"name": "y",    "type": "float* __restrict__",        "desc": "output vector, length M, float32 (write-once)"},
    {"name": "M",    "type": "int",                        "desc": "number of output rows (matrix height)"},
    {"name": "K",    "type": "int",                        "desc": "number of input columns (inner dim, multiple of 256)"}
  ],
  "launch_config": {
    "grid": "(M, 1, 1)",
    "block": "(32, 1, 1)",
    "shared_mem_bytes": 0
  },
  "shapes_qwen35_27b": {
    "_comment": "Qwen3.5-27B has hidden_dim=7168, ffn_dim=~18944, head_dim=128, n_heads=28. Dominant GEMV calls:",
    "q_proj":   {"M": 7168,  "K": 7168},
    "k_proj":   {"M": 1024,  "K": 7168},
    "v_proj":   {"M": 1024,  "K": 7168},
    "o_proj":   {"M": 7168,  "K": 7168},
    "gate_proj": {"M": 18944, "K": 7168},
    "up_proj":   {"M": 18944, "K": 7168},
    "down_proj": {"M": 7168,  "K": 18944}
  },
  "dominant_shapes": [
    {"name": "gate/up_proj", "M": 18944, "K": 7168,  "groups_per_row": 28},
    {"name": "down_proj",    "M": 7168,  "K": 18944, "groups_per_row": 74},
    {"name": "qkv_o_proj",   "M": 7168,  "K": 7168,  "groups_per_row": 28}
  ],
  "memory_layout": {
    "A_per_row_bytes": "groups_per_row * 136",
    "group_layout": "bytes 0-3: scale (f32), bytes 4-7: zero_point (f32), bytes 8-135: packed nibbles (uint32 x 32 = 256 nibbles)",
    "nibble_order": "little-endian: nibble i = (pk[i/8] >> ((i%8)*4)) & 0xF"
  },
  "dequant_formula": "w_float = scale * (float)(nibble) + zero_point",
  "output_formula": "y[row] = sum_{g=0}^{G-1} sum_{i=0}^{255} dequant(A[row,g,i]) * x[g*256+i]",
  "decode_runtime_share": 0.20,
  "prefill_runtime_share": 0.01,
  "amdahl_e2e_at_1_3x": 1.0554,
  "reference_method": "run hipfire bench and capture output float32 tensor via HIPFIRE_DUMP_LAYER_OUT=1 (if available), or use existing kernel as oracle",
  "correctness": {
    "tolerance_abs": 1e-3,
    "tolerance_rel": 1e-4,
    "check_method": "element-wise max abs diff against reference output",
    "num_test_rows": 64,
    "num_test_k": 7168
  },
  "benchmark_command": "ARCH=gfx1201 MODEL=qwen3.5:27b BENCH_TRIALS=3 ./tools/autokernel-rdna/run.sh baseline",
  "correctness_command": "./scripts/coherence-gate-dflash.sh",
  "harness": "tools/autokernel-rdna/kernel_lab/harnesses/gemv_hfq4g256_harness.sh",
  "candidate_dir": "tools/autokernel-rdna/kernel_lab/generated/gemv_hfq4g256/",
  "candidate_pattern": "candidate_N.hip",
  "promotion_target": "kernels/src/gemv_hfq4g256.gfx1201.hip",
  "rollback": "git checkout kernels/src/gemv_hfq4g256.gfx1201.hip crates/rdna-compute/src/kernels.rs",
  "known_negative_results": [
    {
      "commit": "Phase 12 (exp-20260510-002)",
      "description": "8x group unroll + packed uint32 loads — median 93.2 vs 93.1 baseline (+0.1%). gfx1201 already at GDDR6 BW ceiling with 4x unroll. 8x unroll adds VGPR pressure without improving BW throughput.",
      "lesson": "Pure unrolling at current 4x is at BW ceiling. Try LDS staging of x[] instead."
    }
  ]
}
