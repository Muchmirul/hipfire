# autokernel-rdna configuration — copy to config.env and source before running.
# All variables are optional; defaults are shown.
#
# Usage:
#   source tools/autokernel-rdna/config.env
#   ./tools/autokernel-rdna/autokernel_loop.sh
#
# Or inline:
#   ARCH=gfx1201 MODEL=qwen3.5:27b MAX_ITERS=100 ./tools/autokernel-rdna/autokernel_loop.sh

# ── Target and model ─────────────────────────────────────────────────────────

# GPU architecture. gfx1201 = AMD Radeon RX 9070 XT (Navi 44 / RDNA4).
export ARCH="gfx1201"

# Primary model for benchmarking. qwen3.5:27b is the main proof target.
# IMPORTANT: changing to a smaller model (qwen3.5:9b) for smoke-testing is
# supported, but all overnight results must use qwen3.5:27b.
export MODEL="qwen3.5:27b"

# Allow running on hardware other than ARCH (testing / CI use only).
export ALLOW_OTHER_ARCH="0"

# ── Loop control ─────────────────────────────────────────────────────────────

# Maximum number of optimization iterations before the loop stops.
# 100 = short exploratory run (~4-8 hours depending on build speed).
# 300 = aggressive overnight run.
export MAX_ITERS="100"

# Minimum speedup ratio required to ACCEPT a candidate.
# 1.01 = default (1% improvement required — filters noise).
# 1.005 = aggressive overnight (0.5% improvement — accept marginal wins).
# Never set below 1.002 on gfx1201; measurement noise is ~0.3% stddev.
export ACCEPT_MIN_SPEEDUP="1.01"

# Max attempts per kernel target before moving on.
export MAX_ATTEMPTS_PER_TARGET="5"

# Number of bench trials per candidate. Must be >= 3.
export BENCH_TRIALS="3"

# Seconds to allow for each build / bench / correctness operation before TIMEOUT.
export TIMEOUT_SECONDS="1200"

# ── Automatic commit ─────────────────────────────────────────────────────────

# If 1, automatically git-commit accepted candidates with message:
#   autokernel: optimize <target> for gfx1201
# Requires a clean or committed working tree.
export AUTOCOMMIT="0"

# ── Validation ───────────────────────────────────────────────────────────────

# If 1, run phase11_validate.sh after the loop finishes (only if any
# candidates were accepted). Heavy: ~15 min for 27B.
export RUN_FINAL_VALIDATE="0"

# ── Model paths ──────────────────────────────────────────────────────────────

# Override the directory where hipfire models are stored.
# Defaults: ~/.hipfire/models or the Tforce dev mount if present.
# export HIPFIRE_MODELS_DIR="$HOME/.hipfire/models"

# Override which prompt file is used for benching.
# Must be a committed file; MD5 is recorded in every TSV row.
# export HIPFIRE_BENCH_PROMPT="benchmarks/prompts/lru_cache_pep8_strict.txt"

# ── Examples ─────────────────────────────────────────────────────────────────
#
# Short Qwen3.5-27B run (100 iters):
#   ARCH=gfx1201 MODEL=qwen3.5:27b MAX_ITERS=100 \
#     ./tools/autokernel-rdna/autokernel_loop.sh
#
# Overnight aggressive (300 iters, 0.5% threshold, auto-commit):
#   ARCH=gfx1201 MODEL=qwen3.5:27b MAX_ITERS=300 \
#     ACCEPT_MIN_SPEEDUP=1.005 AUTOCOMMIT=1 \
#     ./tools/autokernel-rdna/autokernel_loop.sh
#
# Smoke-test with Qwen3.5-9B (fast, not for final results):
#   ARCH=gfx1201 MODEL=qwen3.5:9b MAX_ITERS=20 \
#     ./tools/autokernel-rdna/autokernel_loop.sh
#
# Stop safely:
#   touch .autokernel_stop       (checked after each iteration)
#   Ctrl-C                       (caught; writes final report before exit)
